{
  "name": "xgr-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "node --watch src/server/server.js",
    "dev:web": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "start": "NODE_ENV=production node src/server/server.js",
    "demo:mock": "DEMO_MODE=mock node src/server/server.js",
    "demo:live": "DEMO_MODE=live node src/server/server.js",
    "package:customer": "node scripts/package-customer.mjs",
    "secrets:encrypt": "node scripts/encrypt-secrets.mjs",
    "secrets:init": "node scripts/init-secrets.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@openai/agents": "^0.1.0",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.15.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {}
}
